# AETHER RMX3171 — Linux 6.6.50 overlay config
#
# Merged ON TOP OF Samsung a05m_defconfig via scripts/kconfig/merge_config.sh.
# Reason: a05m_defconfig is 9599 lines auto-generated; only deltas live here.
# Every line below has a justification comment. No copy-paste-fluff.

# ============================================================
# Build hygiene — disable interactive prompts + skip hdrtest
# (NTFS case-collision lost some lowercase UAPI match headers; hdrtest fails)
# ============================================================
# CONFIG_UAPI_HEADER_TEST is not set
CONFIG_SECTION_MISMATCH_WARN_ONLY=y
# CONFIG_WERROR is not set

# ============================================================
# Identity
# ============================================================
CONFIG_LOCALVERSION="-AETHER-RMX3171-6.6"
# Drop Samsung "-4k" suffix; Realme/MTK does not use 4k page tables on this SoC.
# CONFIG_LOCALVERSION_AUTO is intentionally inherited from Samsung (=y).

# ============================================================
# Module signing — bump SHA1 -> SHA256, drop Samsung MTK build-server key path
# A16 expects stronger signature hashes. SHA1 deprecated.
# ============================================================
# CONFIG_MODULE_SIG_SHA1 is not set
CONFIG_MODULE_SIG_SHA256=y
CONFIG_MODULE_SIG_HASH="sha256"
# Samsung defconfig hardcodes absolute MTK build-server path; drop it so
# kbuild auto-generates a self-signed key at certs/signing_key.pem.
CONFIG_MODULE_SIG_KEY="certs/signing_key.pem"
# CONFIG_MODULE_SIG_PROTECT is not set
CONFIG_MODULE_SIG_ALL=y

# Compress modules to keep vendor_dlkm.img smaller (A16 vendor_dlkm 256 MB cap).
CONFIG_MODULE_COMPRESS_ZSTD=y

# ============================================================
# KernelSU integration
# Use kprobe-based hooks (CONFIG_KPROBES already =y from Samsung defconfig).
# KSU =m would not load early enough for su daemon; keep =y.
# ============================================================
CONFIG_KSU=y
# CONFIG_KSU_DEBUG is not set
# CONFIG_KSU_DISABLE_MANAGER is not set
# CONFIG_KSU_DISABLE_POLICY is not set

# ============================================================
# Magisk co-existence
# Magisk is userspace + boot ramdisk patch. Kernel needs:
# ============================================================
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
# DEVTMPFS / DEVTMPFS_MOUNT already =y on Samsung base.

# ============================================================
# NetHunter on 6.6 — config-driven (no patches needed)
# Most mainline since 4.x; just turn on the bits Kali userspace wants.
# ============================================================
# USB HID gadget for KeyDroid/PowerSploit
CONFIG_USB_CONFIGFS_F_HID=y
# RNDIS gadget for Bad USB Ethernet vector
CONFIG_USB_CONFIGFS_RNDIS=y
# NCM/ECM for USB tethering vector
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_ECM_SUBSET=y
# Mass storage gadget for HID payload delivery
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
# Serial gadget
CONFIG_USB_CONFIGFS_SERIAL=y
# WireGuard for NetHunter VPN tunnels
CONFIG_WIREGUARD=y
# CFG80211 monitor/injection on internal WiFi — limited by MTK proprietary stack
CONFIG_NL80211_TESTMODE=y
CONFIG_CFG80211_WEXT=y
# CONFIG_CFG80211_DEFAULT_PS is not set
CONFIG_MAC80211=y
CONFIG_MAC80211_LEDS=y
# External-USB-WiFi adapter drivers (recommended for real monitor)
CONFIG_RT2X00=m
CONFIG_RT2X00_LIB_USB=m
CONFIG_RT2800USB=m
CONFIG_RT2800USB_RT53XX=y
CONFIG_RT2800USB_RT55XX=y
CONFIG_ATH9K_HTC=m
CONFIG_ATH9K_HTC_DEBUGFS=y
CONFIG_RTL8XXXU=m
CONFIG_RTL8XXXU_UNTESTED=y
CONFIG_MT76_USB=m
CONFIG_MT7601U=m
CONFIG_MT7663U=m

# ============================================================
# ZRAM compressor: prefer LZ4 (faster) for A16; ZSTD fallback for ratio
# ============================================================
CONFIG_ZRAM=m
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_ZSTD=y

# ============================================================
# Filesystems user wants without compile-time fight
# ============================================================
CONFIG_EXFAT_FS=y
CONFIG_FUSE_FS=y
CONFIG_FS_VERITY=y
CONFIG_FS_VERITY_BUILTIN_SIGNATURES=y
# Inline crypto fallback already on from Samsung.

# ============================================================
# Performance: schedutil governor stays default (Samsung base on);
# enable conservative+ondemand for user choice.
# ============================================================
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y

# ============================================================
# MediaTek MT6768/oppo6769 board-specific modules — match RMX3171 hardware
# ============================================================
# Charger PMIC: MT6370 (Realme stock evidence)
CONFIG_MFD_MT6370=m
CONFIG_MT6370_PMU_CHARGER=m
CONFIG_MT6370_PMU_FLED=m
CONFIG_MT6370_PMU_BLED=m
# Main PMIC: MT6358
CONFIG_MFD_MT6358_I2C=m
# Type-C: RT1711H
CONFIG_TYPEC_RT1711H=m
# WLAN connsys: CONSYS_MT6768
CONFIG_MTK_COMBO=m
CONFIG_MTK_COMBO_WIFI=m
CONFIG_MTK_COMBO_BT=m
CONFIG_MTK_COMBO_CHIP_CONSYS_6768=m
# FM radio: MT6631
CONFIG_MTK_FMRADIO=m
CONFIG_MTK_FM_CHIP_MT6631=y
# Sensor hub: Tinysys SCP
CONFIG_MTK_TINYSYS_SCP_SUPPORT=m
# Camera framework
CONFIG_MTK_IMGSENSOR=m
CONFIG_MTK_CAMERA_ISP_SUPPORT=m
CONFIG_MTK_CAMERA_MEM_SUPPORT=m
# GPU framework (Mali G52 MC1 on MT6768)
CONFIG_MTK_GPU_SUPPORT=m
CONFIG_MTK_GPUFREQ_V1=m
# Audio
CONFIG_MTK_AUDIO_IPI=m
CONFIG_SND_SOC_MT6358=m
# Smart PA (Realme custom)
CONFIG_SND_SOC_SIA81XX=m
# Touchscreen — multi-vendor probe (Samsung dtsi covers it)
CONFIG_TOUCHSCREEN_MTK_CHIPONE=m
CONFIG_TOUCHSCREEN_FOCALTECH=m
CONFIG_TOUCHSCREEN_NOVATEK=m
CONFIG_TOUCHSCREEN_OMNIVISION=m
CONFIG_TOUCHSCREEN_GCORE=m
# Fingerprint (Realme uses Goodix primary; ship all three for region builds)
CONFIG_FINGERPRINT_GOODIX=m
CONFIG_FINGERPRINT_EGIS=m
CONFIG_FINGERPRINT_FPC=m

# ============================================================
# Memory tuning for 4 GB RMX3171 variant (lowest sku)
# ============================================================
CONFIG_HIGHMEM=y
CONFIG_ZSWAP_DEFAULT_ON=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y

# ============================================================
# Disable features RMX3171 hardware does not have, to shrink kernel + reduce
# probe spam.
# ============================================================
# NFC: RMX3171 has no NFC controller
# CONFIG_NFC is not set
# 5G modem: not present (G85 4G only)
# CONFIG_MTK_MD_5G is not set
# UFS: not present (eMMC only)
# CONFIG_SCSI_UFSHCD is not set
# CONFIG_SCSI_UFS_MEDIATEK is not set

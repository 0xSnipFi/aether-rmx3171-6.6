# AETHER MTK MT6768 base hardware enable overlay
# Merge onto ACK 6.6 .config via:
#   scripts/kconfig/merge_config.sh -m -O $OUT $OUT/.config aether_mtk_enable.config
#
# Enables MT6768 base drivers that already exist in ACK 6.6 mainline.

# MUST enable platform first — ARCH_MEDIATEK gates all MTK platform drivers
CONFIG_ARCH_MEDIATEK=y

# Pinctrl framework + MT6768 (our port)
CONFIG_PINCTRL_MTK_PARIS=y
CONFIG_PINCTRL_MT6768=y

# eMMC controller (mtk-sd in mainline)
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_MTK=y

# MT6397 MFD framework (covers MT6358 used by MT6768)
CONFIG_MFD_MT6397=y
CONFIG_REGULATOR_MT6358=y
CONFIG_KEYBOARD_MTK_PMIC=y
CONFIG_RTC_DRV_MT6397=y

# Charger PMIC (MT6370)
CONFIG_MFD_MT6370=y
CONFIG_CHARGER_MT6370=y

# PMIC wrapper (essential for any MTK PMIC access)
CONFIG_MTK_PMIC_WRAP=y

# AuxADC (battery voltage measurement)
CONFIG_MEDIATEK_MT6577_AUXADC=y

# AETHER identification
CONFIG_LOCALVERSION="-AETHER-X-RMX3171-A16"

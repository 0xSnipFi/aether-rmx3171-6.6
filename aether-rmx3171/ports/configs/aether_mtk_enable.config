# AETHER MT6768 / Narzo 30A — COMPLETE hardware enable overlay for ACK 6.6
# Apply on top of gki_defconfig or existing .config
# Adds every available MTK driver in ACK 6.6 mainline + key dependencies.

# --- Platform gate ---
CONFIG_ARCH_MEDIATEK=y
CONFIG_LOCALVERSION="-AETHER-X-RMX3171-A16"

# === Pinctrl + GPIO ===
CONFIG_PINCTRL_MTK_PARIS=y
CONFIG_PINCTRL_MT6768=y

# === Storage (eMMC) ===
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_MTK=y
CONFIG_MMC_BLOCK_MINORS=32

# === MT6358 PMIC + regulator + RTC + keys ===
CONFIG_MFD_MT6397=y
CONFIG_REGULATOR_MT6358=y
CONFIG_KEYBOARD_MTK_PMIC=y
CONFIG_RTC_DRV_MT6397=y

# === MT6370 charger + MFD + LED ===
CONFIG_MFD_MT6370=y
CONFIG_CHARGER_MT6370=y
CONFIG_LEDS_MT6370_RGB=y
CONFIG_LEDS_MT6370_FLASH=y

# === PMIC wrapper + AuxADC + battery V/T ===
CONFIG_MTK_PMIC_WRAP=y
CONFIG_MEDIATEK_MT6577_AUXADC=y

# === MTK Bluetooth ===
CONFIG_BT=y
CONFIG_BT_BREDR=y
CONFIG_BT_LE=y
CONFIG_BT_HCIBTSDIO=m
CONFIG_BT_HCIUART=m
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_MTKSDIO=m
CONFIG_BT_MTKUART=m

# === WiFi mt76 (external USB) ===
CONFIG_MT76_CORE=m
CONFIG_MT76_LEDS=y
CONFIG_MT76_USB=m
CONFIG_MT76x0_COMMON=m
CONFIG_MT76x0U=m
CONFIG_MT76x2_COMMON=m
CONFIG_MT76x2U=m
CONFIG_MT7601U=m

# === IOMMU + DMA ===
CONFIG_MTK_IOMMU=y
CONFIG_MTK_IOMMU_V1=y
CONFIG_MTK_HSDMA=y
CONFIG_MTK_UART_APDMA=y

# === Timer + CPUFreq ===
CONFIG_MTK_TIMER=y
CONFIG_ARM_MEDIATEK_CPUFREQ=y
CONFIG_ARM_MEDIATEK_CPUFREQ_HW=y

# === Thermal ===
CONFIG_MTK_THERMAL=y
CONFIG_MTK_LVTS_THERMAL=y

# === I2C + SPI buses ===
CONFIG_I2C=y
CONFIG_I2C_MT65XX=y
CONFIG_SPI=y
CONFIG_SPI_MT65XX=y

# === USB ===
CONFIG_PHY_MTK_TPHY=y
CONFIG_PHY_MTK_HDMI=y
CONFIG_USB_XHCI_MTK=y
CONFIG_USB_MTU3=y

# === USB Type-C ===
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_TCPCI=y
CONFIG_TYPEC_MT6360=m

# === MTK Display DRM ===
CONFIG_DRM=y
CONFIG_DRM_MEDIATEK=y
CONFIG_DRM_MEDIATEK_DSI=y
CONFIG_DRM_MEDIATEK_HDMI=y
CONFIG_DRM_PANEL_NOVATEK_NT36523=m
CONFIG_DRM_PANEL_NOVATEK_NT36672A=m
CONFIG_DRM_PANEL_HIMAX_HX8394=m

# === Audio MT6358 codec + ASoC ===
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_MEDIATEK=y
CONFIG_SND_SOC_MT6358=y

# === Serial console (UART) ===
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_MT6577=y

# === SoC power ===
CONFIG_MTK_INFRACFG=y
CONFIG_MTK_SCPSYS=y
CONFIG_MTK_SCPSYS_PM_DOMAINS=y
CONFIG_MTK_SVS=m
CONFIG_MTK_DEVAPC=m
CONFIG_MTK_MMSYS=y

# === MFD generic MTK ===
CONFIG_MFD_MT6360=y
CONFIG_REGULATOR_MT6315=y
CONFIG_REGULATOR_MT6360=y
CONFIG_CHARGER_MT6360=m

# === SCP firmware loader (sensor hub) ===
CONFIG_FW_LOADER=y
CONFIG_MTK_SCP=m

# === Touchscreen common chips ===
CONFIG_INPUT=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_GOODIX=m
CONFIG_TOUCHSCREEN_GOODIX_BERLIN_CORE=m
CONFIG_TOUCHSCREEN_GOODIX_BERLIN_I2C=m
CONFIG_TOUCHSCREEN_GOODIX_BERLIN_SPI=m
CONFIG_TOUCHSCREEN_FT5X06=m
CONFIG_TOUCHSCREEN_EDT_FT5X06=m
CONFIG_TOUCHSCREEN_SYNAPTICS_RMI4_I2C=m
CONFIG_TOUCHSCREEN_SYNAPTICS_RMI4_SPI=m

# === Watchdog ===
CONFIG_MEDIATEK_WATCHDOG=y

# === Wireless regulatory ===
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_CFG80211_USE_KERNEL_REGDB_KEYS=y
CONFIG_NL80211_TESTMODE=y

# === Scheduler tuning ===
CONFIG_SCHED_MC=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# === Pstore + ramoops (helps debug boot fail) ===
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y

# === Compression ===
CONFIG_LZ4_COMPRESS=y
CONFIG_LZ4_DECOMPRESS=y

# === USB gadget for NetHunter ===
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_F_HID=y
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_WIREGUARD=y

# === fs ===
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_F2FS_FS_XATTR=y
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y

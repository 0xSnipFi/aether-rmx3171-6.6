# AETHER MT6768 / MT6358 / MT6370 hardware enable overlay for ACK 6.6
# Merge: scripts/kconfig/merge_config.sh -m -O $OUT $OUT/.config aether_mtk_enable.config
#
# Enables every MTK driver available in ACK 6.6 mainline that's useful for
# MT6768 (Helio G80/G85) devices: Realme Narzo 30A, Samsung Galaxy A05M, etc.

# --- Platform gate (REQUIRED first) ---
CONFIG_ARCH_MEDIATEK=y

# --- AETHER kernel name ---
CONFIG_LOCALVERSION="-AETHER-X-RMX3171-A16"

# === Pinctrl ===
CONFIG_PINCTRL_MTK_PARIS=y
CONFIG_PINCTRL_MT6768=y

# === eMMC storage ===
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_MTK=y

# === MT6358 PMIC + regulator ===
CONFIG_MFD_MT6397=y
CONFIG_REGULATOR_MT6358=y
CONFIG_KEYBOARD_MTK_PMIC=y
CONFIG_RTC_DRV_MT6397=y

# === MT6370 charger + MFD ===
CONFIG_MFD_MT6370=y
CONFIG_CHARGER_MT6370=y
CONFIG_LEDS_MT6370_RGB=y
CONFIG_LEDS_MT6370_FLASH=y

# === PMIC wrapper bus + AuxADC ===
CONFIG_MTK_PMIC_WRAP=y
CONFIG_MEDIATEK_MT6577_AUXADC=y

# === Bluetooth MTK chips ===
CONFIG_BT=y
CONFIG_BT_BREDR=y
CONFIG_BT_LE=y
CONFIG_BT_HCIBTSDIO=m
CONFIG_BT_HCIUART=m
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_MTKSDIO=m
CONFIG_BT_MTKUART=m

# === WiFi mt76 (USB external) ===
CONFIG_MT76_CORE=m
CONFIG_MT76_LEDS=y
CONFIG_MT76_USB=m
CONFIG_MT76x0_COMMON=m
CONFIG_MT76x0U=m
CONFIG_MT76x2_COMMON=m
CONFIG_MT76x2U=m
CONFIG_MT7601U=m

# === IOMMU ===
CONFIG_MTK_IOMMU=y
CONFIG_MTK_IOMMU_V1=y

# === Timer + clocksource ===
CONFIG_MTK_TIMER=y

# === CPUFreq ===
CONFIG_ARM_MEDIATEK_CPUFREQ=y
CONFIG_ARM_MEDIATEK_CPUFREQ_HW=y

# === Thermal (LVTS for MT6768-class, auxadc_thermal for older) ===
CONFIG_MTK_THERMAL=y
CONFIG_MTK_LVTS_THERMAL=y

# === I2C (essential for sensors/touch/charger) ===
CONFIG_I2C=y
CONFIG_I2C_MT65XX=y

# === SPI (often used for touch + display) ===
CONFIG_SPI=y
CONFIG_SPI_MT65XX=y

# === USB MTK ===
CONFIG_PHY_MTK_TPHY=y
CONFIG_PHY_MTK_HDMI=y
CONFIG_USB_XHCI_MTK=y
CONFIG_USB_MTU3=y

# === MTK display DRM (mainline) ===
CONFIG_DRM=y
CONFIG_DRM_MEDIATEK=y
CONFIG_DRM_MEDIATEK_DSI=y
CONFIG_DRM_MEDIATEK_HDMI=y

# === Audio MTK ===
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_MEDIATEK=y

# === DMA + serial ===
CONFIG_MTK_HSDMA=y
CONFIG_MTK_UART_APDMA=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_MT6577=y

# === SoC + power ===
CONFIG_MTK_INFRACFG=y
CONFIG_MTK_PMIC_WRAP=y
CONFIG_MTK_SCPSYS=y
CONFIG_MTK_SCPSYS_PM_DOMAINS=y
CONFIG_MTK_SVS=m

# === MTK MFD generic ===
CONFIG_MFD_MT6360=y
CONFIG_REGULATOR_MT6315=y

# === Touchscreen common chips found on MT6768 phones ===
CONFIG_TOUCHSCREEN_GOODIX=m
CONFIG_TOUCHSCREEN_GOODIX_BERLIN_CORE=m
CONFIG_TOUCHSCREEN_GOODIX_BERLIN_I2C=m
CONFIG_TOUCHSCREEN_GOODIX_BERLIN_SPI=m
CONFIG_TOUCHSCREEN_FT5X06=m
CONFIG_TOUCHSCREEN_SYNAPTICS_RMI4_I2C=m
CONFIG_TOUCHSCREEN_SYNAPTICS_RMI4_SPI=m

# === Fingerprint sensors (Goodix family) ===
CONFIG_INPUT=y
# (Goodix-FP is vendor MTK driver; needs port from 4.14 separately)

# === Networking essentials (already in ACK base) ===
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_WIRELESS=y
CONFIG_WLAN=y

# === KernelSU (already added by aetherx build_kernel.sh) ===
# CONFIG_KSU handled by upstream KernelSU setup.sh

# === Performance / scheduler tuning ===
CONFIG_SCHED_MC=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

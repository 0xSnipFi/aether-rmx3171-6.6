# AETHER RMX3171 — system_dlkm.modules.load
#
# GKI mainline 6.6 kernel modules mounted to /system_dlkm by 2nd-stage init.
# A16 GKI 2.0 split: GKI modules (any device runs) here; vendor-specific in
# vendor_dlkm.modules.load.

# === MTK mainline 6.6 generic ===
mtk-uart-apdma.ko
mtk-hsdma.ko
mtk_scp.ko
mtk_scp_ipi.ko
mediatek-cpufreq-hw.ko

# === MFD generic ===
mt6360-core.ko

# === Charger/Type-C mainline ===
mt6360_charger.ko
tcpci_mt6360.ko

# === Touch generic ===
goodix_ts.ko
edt-ft5x06.ko

# === Mali external USB WiFi (mt76 family) ===
mt76.ko
mt76-usb.ko
mt76x0-common.ko
mt76x0u.ko
mt76x2-common.ko
mt76x2u.ko
mt7601u.ko

# === Bluetooth mainline ===
btmtk.ko
btmtksdio.ko
btmtkuart.ko

# === Crypto ===
sha256_generic.ko
aes_arm64.ko

# === Filesystems ===
overlay.ko
fuse.ko

# === Net ===
wireguard.ko
